# 阿里云百炼 DashScope API Key
# 申请地址：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key

# 聊天模型 Provider：dashscope 或 mimo
CHAT_PROVIDER=dashscope

# 小米 MiMo Token Plan / OpenAI 兼容配置
MIMO_API_KEY=your-mimo-api-key
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_CHAT_MODEL=mimo-v2.5-pro

# Embedding Provider：dashscope 或 local
# local 适合只想用一个聊天模型 key 跑通 demo；正式 RAG 建议使用 DashScope embedding。
EMBEDDING_PROVIDER=dashscope

# 默认模型配置见 config/rag.yml：
# chat_model_name: qwen3-max
# embedding_model_name: text-embedding-v4
